# App environment: development | staging | production
NUXT_PUBLIC_APP_ENV=development

# App URL (for redirects and links). No trailing slash.
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (create a project at https://supabase.com)
# Use separate projects for development, staging, and production.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Server-only: service role key (never expose to client). Used for admin API and db:seed.
NUXT_SUPABASE_SERVICE_ROLE_KEY=
# Alternative names (nuxt.config maps these so the Supabase module finds the key):
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SERVICE_KEY=

# Optional: override public runtime config (Nuxt will map these to runtimeConfig.public)
# NUXT_PUBLIC_SUPABASE_URL=
# NUXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth: enable in Supabase Dashboard → Authentication → Providers → Google.
# Add your app URL (e.g. http://localhost:3000 and production URL) to Redirect URLs in Supabase.
# NUXT_PUBLIC_APP_URL must match the URL users use (required for OAuth redirect).
# NUXT_PUBLIC_GOOGLE_CLIENT_ID=
# Web Push (chat notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Optional explicit public runtime override (otherwise VAPID_PUBLIC_KEY is used)
# NUXT_PUBLIC_VAPID_PUBLIC_KEY=
